{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.SemanticKernel": "Information",
        "Microsoft.SemanticKernel.Agents": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/agents-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:HH:mm:ss.fff} [{Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  "OpenTelemetry": {
    "ServiceName": "MagenticWorkflowApp"
  },

  "Ollama": {
    "Endpoint": "http://localhost:11434",
    "DefaultModelId": "hadad/qwen3-4bd:Q8_0"
  },

  "Tavily": {
    "ApiKey": "",
    "MaxResults": 5,
    "SearchDepth": "advanced",
    "IncludeAnswer": true,
    "Endpoint": "https://api.tavily.com/search"
  },

  "Serper": {
    "ApiKey": "",
    "Endpoint": "https://google.serper.dev/search",
    "Language": "ru",
    "Country": null,
    "MaxResults": 5
  },

  "DeepResearch": {
    "MaxResearchIterations": 2,
    "ChatReducerWindow": 10,
    "MaxParallelResearchers": 4,
    "MaxClarifierTurns": 5,
    "SessionsDir": "./sessions",
    "ReportsDir": "./reports"
  },

  "WorkflowSettings": {
    "DefaultConfigPath": "workflow-sum.json",
    "EnableDetailedLogging": true,
    "SaveVisualizationToFile": false
  }
}
